{
  "httpHeaders": [
    {
      "urls": ["docs.aws.amazon.com", "repost.aws"],
      "headers": {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0.0.0 Safari/537.36",
        "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8"
      }
    },
    {
      "urls": ["w3.org"],
      "headers": {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36"
      }
    }
  ],
  "ignorePatterns": [
    {
      "pattern": "^http://localhost"
    },
    {
      "pattern": "^127.0.0.1"
    },
    {
      "pattern": "^example.com"
    },
    {
      "pattern": "^github.com/aws/aws-networking-best-practices"
    },
    {
      "pattern": "^https://www.w3.org/WAI/WCAG21/Understanding/contrast-minimum.html"
    },
    {
      "pattern": "^https://github.com/aws/aws-networking-best-practices"
    }
  ],
  "timeout": "20s",
  "retryOn429": true,
  "retryCount": 3,
  "fallbackRetryDelay": "30s",
  "aliveStatusCodes": [200, 206, 999],
  "ignoreHttpsErrors": true,
  "replacementPatterns": [
    {
      "pattern": "^community/([^/]+)/$",
      "replacement": "community/$1.md"
    }
  ]
}
